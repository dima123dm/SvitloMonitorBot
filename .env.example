# Токен бота від @BotFather
BOT_TOKEN=your_bot_token_here

# ID адмінів (через кому якщо декілька)
ADMIN_IDS=123456789

# Основне API (DTEK Proxy)
PRIMARY_API_URL=https://dtek-api.svitlo-proxy.workers.dev/

# Резервне API
BACKUP_API_URL=https://svitlo-proxy.svitlo-proxy.workers.dev/api/v2/homeassistant/regions

# База даних
DB_NAME=users.db

# Інтервал перевірки оновлень (секунди, 900 = 15 хв)
UPDATE_INTERVAL=900

# Failover: через скільки секунд перемикатись (7200 = 2 години)
FAILOVER_TIMEOUT=7200

# Recovery: через скільки перевіряти основне API (86400 = 24 години)
RECOVERY_CHECK_INTERVAL=86400
